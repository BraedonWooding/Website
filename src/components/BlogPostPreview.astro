---
import { BlogFrontMatter } from "../shared/types";

export interface Props {
	post: {
		frontmatter: BlogFrontMatter
	}
}

const { post } = Astro.props;
---

<article class="ml-10 border-b-2 pb-5">
	<header>
		<p class="text-[#868686]">{new Date(post.frontmatter.publishDate).toLocaleString("default", { dateStyle: "full"
			})}
		</p>
		<a href={post.url}>
			<h1>{post.frontmatter.title}</h1>
		</a>
		<h3 class="text-[#63666A]">| {post.frontmatter.subTitle}</h3>

	</header>
	<p pl-10>{post.frontmatter.description}</p>
	<a href={post.url}>Read more...</a>
</article>
<style>
	a,
	a:visited,
	a:hover,
	a:active {
		color: inherit;
	}
</style>